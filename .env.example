# =========================
# ClawShield runtime paths
# =========================
# Policy directory (default: policies/base)
CLAWSHIELD_POLICY_DIR=policies/base

# Incident log file (default: data/incidents/incidents.jsonl)
CLAWSHIELD_INCIDENT_PATH=data/incidents/incidents.jsonl

# Runtime/session state directory (default: data/runtime)
CLAWSHIELD_RUNTIME_DIR=data/runtime

# Optional project root override (usually leave empty)
# CLAWSHIELD_PROJECT_ROOT=/absolute/path/to/project


# ======================================
# Guard LLM judge (choose ONE provider)
# ======================================

# --- Option A: OpenAI-compatible API ---
# GUARD_API_TYPE=openai
# GUARD_API_BASE=https://api.openai.com/v1
# GUARD_API_KEY=your_openai_or_compatible_key
# GUARD_MODEL=gpt-4.1-mini

# --- Option B: Anthropic API ---
# GUARD_API_TYPE=anthropic
# GUARD_API_BASE=https://api.anthropic.com/v1
# GUARD_API_KEY=your_anthropic_key
# GUARD_MODEL=claude-3-5-sonnet-latest
